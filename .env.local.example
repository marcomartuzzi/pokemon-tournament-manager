# Copia questo file in .env.local e sostituisci i valori con quelli del tuo progetto Firebase.
# Trovi questi valori in: Firebase Console > Impostazioni progetto > Le tue app > Configurazione SDK

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=il-tuo-progetto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=il-tuo-progetto
VITE_FIREBASE_STORAGE_BUCKET=il-tuo-progetto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
